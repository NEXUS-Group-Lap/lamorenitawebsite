---
import Icon from './Icon.astro';
---
<div class="announcement" role="status">
  <div class="container announcement-inner">
    <span class="announcement-icon"><Icon name="package" size={18} /></span>
    <p class="announcement-text">
      <strong>Próximamente en Uber Eats y DoorDash</strong> — estén atentos
    </p>
  </div>
</div>

<style>
  .announcement {
    position: relative;
    overflow: hidden;
    margin-top: var(--header-height);
    background: linear-gradient(90deg, var(--accent), var(--gold-dark));
    color: var(--white);
  }

  .announcement::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    left: -60%;
    width: 40%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
    animation: announcement-shimmer 3s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes announcement-shimmer {
    0% { left: -60%; }
    100% { left: 120%; }
  }

  .announcement-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    text-align: center;
    padding: 10px 24px;
  }

  .announcement-icon {
    display: flex;
    flex-shrink: 0;
    animation: announcement-bounce 1.6s ease-in-out infinite;
  }

  @keyframes announcement-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }

  .announcement-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.5;
  }

  @media (min-width: 640px) {
    .announcement-inner { flex-wrap: nowrap; gap: 14px; }
    .announcement-text { font-size: 0.9rem; }
  }
</style>
