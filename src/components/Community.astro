---
import Icon from './Icon.astro';
const flagsImg = `${import.meta.env.BASE_URL}flags.png`;
---
<section class="section" id="servicios" aria-labelledby="community-title">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Servicios</span>
      <h2 id="community-title">Servicios para nuestra comunidad</h2>
    </div>
    <div class="flags-banner reveal">
      <p class="flags-caption">Enviamos dinero y paquetes a toda Latinoamérica</p>
      <img src={flagsImg} alt="Banderas de países de Latinoamérica y Estados Unidos" loading="lazy" />
    </div>
    <div style="text-align:center; margin-top:28px;" class="reveal">
      <a href="tel:+12395609478" class="btn btn-primary"><Icon name="phone" size={18} /> Llámanos para más detalles</a>
    </div>
  </div>
</section>

<style>
  .flags-banner {
    text-align: center;
    margin-bottom: 32px;
  }
  .flags-caption {
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--navy);
    margin-bottom: 14px;
  }
  .flags-banner img {
    width: 100%;
    max-width: 480px;
    height: auto;
    display: block;
    margin: 0 auto;
  }
</style>
