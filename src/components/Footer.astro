---
import Icon from './Icon.astro';
---
<footer class="footer" role="contentinfo">
  <div class="container">
    <h4>Pulpería La Morenita</h4>
    <p>Productos centroamericanos • Comida preparada • Envíos de dinero • Paquetes</p>
    <p class="footer-line"><Icon name="map-pin" size={16} /> 895 Pondella Rd, North Fort Myers, FL 33903</p>
    <p class="footer-line"><Icon name="phone" size={16} /> +1 (239) 560-9478</p>
    <p class="footer-line"><Icon name="languages" size={16} /> Hablamos español e inglés</p>
    <div class="footer-links">
      <a href="https://www.facebook.com/pulperia.la.morenita" target="_blank" rel="noopener"><Icon name="facebook" size={16} /> Facebook</a>
      <a href="https://www.instagram.com/pulperialamorenita/" target="_blank" rel="noopener"><Icon name="instagram" size={16} /> Instagram</a>
      <a href="https://www.tiktok.com/@pulperialamorenita" target="_blank" rel="noopener"><Icon name="tiktok" size={16} /> TikTok</a>
      <a href="https://maps.app.goo.gl/MEhpMWyCHFsVHLnS9" target="_blank" rel="noopener"><Icon name="map-pin" size={16} /> Google Maps</a>
    </div>
    <p class="footer-disclaimer">Los precios, productos, platos y servicios pueden cambiar sin previo aviso. Para confirmar disponibilidad, llama o envía mensaje por WhatsApp antes de visitar.</p>
  </div>
</footer>

<!-- Sticky mobile bar -->
<div class="sticky-bar" role="navigation" aria-label="Acciones rápidas móvil">
  <a href="https://maps.app.goo.gl/MEhpMWyCHFsVHLnS9" target="_blank" rel="noopener" class="btn btn-white"><Icon name="map-pin" size={16} /> Llegar</a>
  <a href="https://wa.me/12395609478" target="_blank" rel="noopener" class="btn btn-primary"><Icon name="whatsapp" size={16} /> WhatsApp</a>
  <a href="tel:+12395609478" class="btn btn-outline"><Icon name="phone" size={16} /> Llamar</a>
</div>

<style>
  .footer {
    background: var(--navy);
    color: rgba(255,255,255,0.8);
    padding: 50px 0 100px;
    text-align: center;
  }
  @media (min-width: 768px) { .footer { padding: 50px 0; } }

  .footer h4 { color: var(--white); margin-bottom: 8px; }
  .footer p { margin-bottom: 6px; font-size: 0.9rem; }
  .footer-line {
    display: flex; align-items: center; justify-content: center; gap: 8px;
  }

  .footer-links {
    display: flex; flex-wrap: wrap; gap: 14px;
    justify-content: center; margin: 18px 0;
  }
  .footer-links a {
    display: flex; align-items: center; gap: 6px;
    color: rgba(255,255,255,0.7); font-size: 0.9rem; transition: color var(--transition-fast);
  }
  .footer-links a:hover { color: var(--white); }

  .footer-disclaimer { font-size: 0.78rem; color: rgba(255,255,255,0.5); margin-top: 16px; }

  .sticky-bar {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: var(--white);
    border-top: 1px solid rgba(0,0,0,0.08);
    display: flex; gap: 8px;
    padding: 10px 16px;
    z-index: 998;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
  }
  .sticky-bar .btn { flex: 1; padding: 13px 10px; font-size: 0.85rem; }
  @media (min-width: 768px) { .sticky-bar { display: none; } }
</style>
