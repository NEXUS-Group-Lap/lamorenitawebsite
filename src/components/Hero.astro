---
import Icon from './Icon.astro';
const heroImg = `${import.meta.env.BASE_URL}front.png`;
const heroBgImg = `${import.meta.env.BASE_URL}interior6.jpg`;
const flagsImg = `${import.meta.env.BASE_URL}flags2division.png`;
---
<section class="hero" aria-labelledby="hero-title" style={`--hero-bg-img: url(${heroBgImg})`}>
  <div class="hero-bg-pattern"></div>
  <div class="container hero-grid">
    <div class="hero-content">
      <h1 class="hero-title" id="hero-title">Pulpería<br />La Morenita</h1>
      <p class="hero-subtitle">Productos latinos, comida preparada y servicios para tu familia en North Fort Myers.</p>
      <p class="hero-description">Encuentra productos centroamericanos, tortillas de maíz, abarrotes, bebidas, comida latina, envíos de dinero y paquetes internacionales en un solo lugar.</p>

      <div class="hero-info">
        <span class="hero-info-item"><Icon name="clock" size={16} /> 7 AM – 9 PM</span>
        <span class="hero-info-item"><Icon name="map-pin" size={16} /> 895 Pondella Rd</span>
        <span class="hero-info-item"><Icon name="languages" size={16} /> Español e inglés</span>
      </div>

      <div class="hero-btns">
        <a href="https://maps.app.goo.gl/MEhpMWyCHFsVHLnS9" target="_blank" rel="noopener" class="btn btn-white btn-lg"><Icon name="map-pin" size={18} /> Cómo llegar</a>
        <a href="https://wa.me/12395609478" target="_blank" rel="noopener" class="btn btn-primary btn-lg"><Icon name="whatsapp" size={18} /> WhatsApp</a>
        <a href="tel:+12395609478" class="btn btn-outline-white btn-lg"><Icon name="phone" size={18} /> Llamar ahora</a>
      </div>

    </div>

    <aside class="hero-card">
      <img
        class="hero-card-img"
        src={heroImg}
        alt="Refrigerador de bebidas dentro de Pulpería La Morenita"
        loading="eager"
      />
      <div class="hero-card-overlay">
        <div class="hero-card-status">
        </div>
        <div class="hero-card-foot">
          <Icon name="map-pin" size={16} />
          <span>895 Pondella Rd, North Fort Myers, FL</span>
        </div>
        <a href="#ubicacion" class="hero-card-link">
          Ver ubicación <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </aside>
  </div>
  <img src={flagsImg} alt="Banderas de Latinoamérica" class="hero-flags-banner" loading="lazy" />
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - var(--header-height));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #07111f;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: var(--hero-bg-img) center 30% / cover no-repeat;
    z-index: 0;
  }

  .hero-bg-pattern {
    position: absolute; inset: 0;
    background:
      linear-gradient(160deg, rgba(7,17,31,0.92) 0%, rgba(8,59,117,0.85) 35%, rgba(11,111,212,0.7) 70%, rgba(17,141,255,0.55) 100%),
      radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px),
      radial-gradient(ellipse at 25% 20%, rgba(17,141,255,0.35) 0%, transparent 50%),
      radial-gradient(ellipse at 75% 60%, rgba(21,101,192,0.3) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 80%, rgba(8,59,117,0.4) 0%, transparent 50%);
    background-size: cover, 28px 28px, auto, auto, auto;
    z-index: 1;
  }

  .hero-bg-pattern::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 6px;
    background: linear-gradient(90deg, var(--accent) 0 25%, var(--gold) 25% 50%, var(--white) 50% 75%, var(--primary) 75% 100%);
    opacity: 0.85;
  }

  .hero-grid {
    position: relative; z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
    padding: 40px 0;
  }
  @media (min-width: 1024px) {
    .hero-grid { grid-template-columns: 1.2fr 0.8fr; gap: 60px; }
  }

  .hero-content {
    color: var(--white);
    max-width: 620px;
  }

  .hero-title {
    color: var(--white); margin-bottom: 20px;
    animation: fadeInUp 0.8s 0.1s ease forwards;
    opacity: 0; animation-fill-mode: forwards;
  }

  .hero-subtitle {
    font-size: 1.15rem; color: rgba(255,255,255,0.9);
    margin-bottom: 12px;
    animation: fadeInUp 0.8s 0.2s ease forwards;
    opacity: 0; animation-fill-mode: forwards;
    max-width: 550px;
  }

  .hero-description {
    color: rgba(255,255,255,0.8); margin-bottom: 28px;
    animation: fadeInUp 0.8s 0.3s ease forwards;
    opacity: 0; animation-fill-mode: forwards;
    max-width: 520px; line-height: 1.7;
  }

  .hero-info {
    display: flex; flex-wrap: wrap; gap: 16px;
    margin-bottom: 32px;
    animation: fadeInUp 0.8s 0.4s ease forwards;
    opacity: 0; animation-fill-mode: forwards;
  }

  .hero-info-item {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.9rem; color: rgba(255,255,255,0.9);
    background: rgba(255,255,255,0.08);
    padding: 10px 16px; border-radius: 50px;
    backdrop-filter: blur(6px);
  }

  .hero-btns {
    display: flex; flex-wrap: wrap; gap: 12px;
    animation: fadeInUp 0.8s 0.5s ease forwards;
    opacity: 0; animation-fill-mode: forwards;
  }

  .hero-card {
    position: relative;
    display: block;
    border-radius: var(--radius-xl);
    overflow: hidden;
    color: var(--white);
    animation: fadeInUp 0.8s 0.3s ease forwards;
    opacity: 0; animation-fill-mode: forwards;
    box-shadow: var(--shadow-lg);
    aspect-ratio: 4/3;
    border: 1px solid rgba(255,255,255,0.18);
    margin-top: 8px;
  }
  @media (min-width: 1024px) {
    .hero-card {
      box-shadow: var(--shadow-xl);
      aspect-ratio: 4/5;
      margin-top: 0;
    }
  }

  .hero-card-img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }

  .hero-card-overlay {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; justify-content: flex-end;
    gap: 14px;
    padding: 24px;
    background: linear-gradient(180deg, rgba(7,17,31,0) 35%, rgba(7,17,31,0.85) 100%);
  }

  .hero-card-status {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.85rem; font-weight: 600;
    color: rgba(255,255,255,0.95);
    align-self: flex-start;
    background: rgba(7,17,31,0.45);
    backdrop-filter: blur(6px);
    border-radius: 50px;
    padding: 6px 14px;
  }
  .status-dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 0 4px rgba(74,222,128,0.2);
  }

  .hero-card-foot {
    display: flex; align-items: center; gap: 10px;
    font-size: 0.85rem; color: rgba(255,255,255,0.85);
  }

  .hero-card-link {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600; font-size: 0.9rem;
    color: var(--white);
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    backdrop-filter: blur(6px);
    border-radius: 50px;
    padding: 10px 18px;
    width: fit-content;
    transition: all var(--transition-fast);
  }
  .hero-card-link:hover {
    background: rgba(255,255,255,0.25);
    transform: translateX(2px);
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-flags-banner {
    position: relative; z-index: 2;
    display: block;
    width: 100%;
    height: 28px;
    object-fit: cover;
    object-position: center;
    margin-top: 24px;
    opacity: 0.92;
  }
  @media (min-width: 1024px) {
    .hero-flags-banner { height: 36px; }
  }
</style>
