---
import Icon from './Icon.astro';
---
<section class="section" id="ubicacion" aria-labelledby="location-title">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Ubicación</span>
      <h2 id="location-title">Visítanos</h2>
      <p>Estamos en el corazón de North Fort Myers, listos para atenderte.</p>
    </div>
    <div class="location-grid">
      <div class="location-info reveal">
        <h3>Pulpería La Morenita</h3>
        <p><Icon name="map-pin" size={18} /> 895 Pondella Rd<br />North Fort Myers, FL 33903</p>
        <p><Icon name="clock" size={18} /> <strong>Horario:</strong> 7:00 AM – 9:00 PM</p>
        <p><Icon name="phone" size={18} /> <strong>Teléfono:</strong> +1 (239) 560-9478</p>
        <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top:18px;">
          <a href="https://maps.app.goo.gl/MEhpMWyCHFsVHLnS9" target="_blank" rel="noopener" class="btn btn-primary"><Icon name="map-pin" size={18} /> Cómo llegar</a>
          <a href="https://wa.me/12395609478" target="_blank" rel="noopener" class="btn btn-white"><Icon name="whatsapp" size={18} /> WhatsApp</a>
          <a href="tel:+12395609478" class="btn btn-outline"><Icon name="phone" size={18} /> Llamar ahora</a>
        </div>
      </div>
      <div class="location-map reveal reveal-delay-1">
        <iframe
          src="https://maps.google.com/maps?q=895+Pondella+Rd,+North+Fort+Myers,+FL+33903&output=embed"
          title="Mapa de ubicación de Pulpería La Morenita"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .location-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
    align-items: center;
  }
  @media (min-width: 768px) { .location-grid { grid-template-columns: 1fr 1fr; gap: 50px; } }

  .location-info h3 { margin-bottom: 12px; }
  .location-info p {
    margin-bottom: 8px; color: var(--text-body);
    display: flex; align-items: flex-start; gap: 8px;
  }
  .location-info p :global(.icon) { color: var(--primary); flex-shrink: 0; margin-top: 3px; }

  .location-map {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    aspect-ratio: 16/10;
    background: var(--gray-light);
    transition: all var(--transition-smooth);
  }
  .location-map:hover { box-shadow: var(--shadow-lg); }
  .location-map iframe {
    width: 100%; height: 100%;
    border: 0; display: block;
  }
</style>
