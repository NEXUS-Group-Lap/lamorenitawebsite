---
import Icon from './Icon.astro';
---
<section class="section bg-cream" aria-labelledby="social-title">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">Redes sociales</span>
      <h2 id="social-title">Síguenos en redes</h2>
      <p>Conoce más sobre nuestro día a día y nuestras novedades.</p>
    </div>
    <div class="social-grid reveal reveal-delay-1">
      <a href="https://www.facebook.com/pulperia.la.morenita" target="_blank" rel="noopener" class="social-link"><Icon name="facebook" size={18} /> Facebook</a>
      <a href="https://www.instagram.com/pulperialamorenita/" target="_blank" rel="noopener" class="social-link"><Icon name="instagram" size={18} /> Instagram</a>
      <a href="https://www.tiktok.com/@pulperialamorenita" target="_blank" rel="noopener" class="social-link"><Icon name="tiktok" size={18} /> TikTok</a>
      <a href="https://www.google.com/maps/place/Pulperia+La+Morenita/@26.666742,-81.9147759,17z" target="_blank" rel="noopener" class="social-link"><Icon name="map-pin" size={18} /> Google Maps</a>
    </div>
  </div>
</section>

<style>
  .social-grid { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }

  .social-link {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 22px; border-radius: 50px;
    font-weight: 600; font-size: 0.9rem;
    transition: all var(--transition-smooth);
    background: var(--white); color: var(--text-dark);
    box-shadow: var(--shadow-sm);
  }
  .social-link:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); color: var(--primary); }
</style>
